const ATTACHMENT_POLICY=Object.freeze({MAX_BYTES:8*1024*1024,ALLOWED_MIME:['image/jpeg','image/png','image/webp','application/pdf']});
function listAttachments_(auth,payload){requirePermission_(auth.user,'patients.read');const patient=getPatientRecordInScope_(auth.user,payload.patientId);if(!patient)throw createAppError_('NOT_FOUND','ไม่พบผู้ป่วย');return recordsForField_('ATTACHMENTS','patient_id',patient.patient_id).filter(function(a){return !a.archived_at&&canAccessAttachment_(auth.user,a);}).map(publicAttachment_);}
function uploadAttachment_(auth,payload,requestId){requirePermission_(auth.user,'patients.write');const patient=getPatientRecordInScope_(auth.user,payload.patientId);if(!patient)throw createAppError_('NOT_FOUND','ไม่พบผู้ป่วย');const mime=String(payload.mimeType||'').toLowerCase();if(ATTACHMENT_POLICY.ALLOWED_MIME.indexOf(mime)===-1)throw createAppError_('FILE_REJECTED','รองรับเฉพาะ JPG, PNG, WEBP และ PDF');const base64=String(payload.contentBase64||'').replace(/^data:[^;]+;base64,/,'');let bytes;try{bytes=Utilities.base64Decode(base64);}catch(e){throw createAppError_('FILE_REJECTED','ไฟล์ไม่ใช่ Base64 ที่ถูกต้อง');}if(!bytes.length||bytes.length>ATTACHMENT_POLICY.MAX_BYTES)throw createAppError_('FILE_REJECTED','ไฟล์ต้องมีขนาดไม่เกิน 8 MB');if(!matchesFileSignature_(bytes,mime))throw createAppError_('FILE_REJECTED','ชนิดไฟล์ไม่ตรงกับเนื้อหา');const consent=validConsentForAttachment_(patient.patient_id,payload.consentId);if(!consent&&String(payload.fileCategory||'')!=='CLINICAL_DOCUMENT_LEGAL_BASIS')throw createAppError_('CONSENT_REQUIRED','ไม่พบ consent ที่ยังมีผลสำหรับไฟล์นี้');const config=getRuntimeConfig_();if(!config.driveFolderId)throw createAppError_('STORAGE_NOT_CONFIGURED','ยังไม่ได้ตั้งค่า DRIVE_FOLDER_ID');const now=new Date();const attachmentId=Utilities.getUuid();const extension=mime==='image/jpeg'?'.jpg':mime==='image/png'?'.png':mime==='image/webp'?'.webp':'.pdf';const safeName=attachmentId+extension;const blob=Utilities.newBlob(bytes,mime,safeName);const folder=DriveApp.getFolderById(config.driveFolderId);const file=folder.createFile(blob);file.setDescription(JSON.stringify({attachmentId:attachmentId,patientId:patient.patient_id,uploadedAt:now.toISOString()}));const record={attachment_id:attachmentId,patient_id:patient.patient_id,visit_id:String(payload.visitId||''),file_category:safeCellText_(payload.fileCategory,100),drive_file_id:file.getId(),original_name:safeCellText_(payload.originalName,300),mime_type:mime,size_bytes:bytes.length,sha256:bytesToHex_(Utilities.computeDigest(Utilities.DigestAlgorithm.SHA_256,bytes)),caption:safeCellText_(payload.caption,1000),captured_at:String(payload.capturedAt||now.toISOString()),consent_id:consent?consent.consent_id:'',uploaded_by:auth.user.user_id,access_level:String(payload.accessLevel||'CARE_TEAM'),archived_at:'',created_at:now.toISOString(),created_by:auth.user.user_id,updated_at:now.toISOString(),updated_by:auth.user.user_id,row_version:1,is_active:true};appendRecord_('ATTACHMENTS',record);appendAudit_({requestId:requestId,actorUserId:auth.user.user_id,organizationId:patient.organization_id,actionCode:'ATTACHMENT_UPLOAD',entityType:'ATTACHMENT',entityId:attachmentId,changedFields:['file_category','mime_type','size_bytes']});return publicAttachment_(record);}
function getAttachmentContent_(auth,payload,requestId){requirePermission_(auth.user,'patients.read');const found=findRecordByField_('ATTACHMENTS','attachment_id',String(payload.attachmentId||'').toLowerCase());if(!found||found.record.archived_at)throw createAppError_('NOT_FOUND','ไม่พบไฟล์');const patient=getPatientRecordInScope_(auth.user,found.record.patient_id);if(!patient||!canAccessAttachment_(auth.user,found.record))throw createAppError_('FORBIDDEN','ไม่มีสิทธิ์ดูไฟล์นี้');const file=DriveApp.getFileById(String(found.record.drive_file_id));const blob=file.getBlob();appendAudit_({requestId:requestId,actorUserId:auth.user.user_id,organizationId:patient.organization_id,actionCode:'ATTACHMENT_VIEW',entityType:'ATTACHMENT',entityId:found.record.attachment_id});return{attachmentId:String(found.record.attachment_id),fileName:String(found.record.original_name||file.getName()),mimeType:String(found.record.mime_type),contentBase64:Utilities.base64Encode(blob.getBytes())};}
function archiveAttachment_(auth,payload,requestId){requirePermission_(auth.user,'patients.write');const found=findRecordByField_('ATTACHMENTS','attachment_id',String(payload.attachmentId||'').toLowerCase());if(!found)throw createAppError_('NOT_FOUND','ไม่พบไฟล์');const patient=getPatientRecordInScope_(auth.user,found.record.patient_id);if(!patient)throw createAppError_('FORBIDDEN','ไม่มีสิทธิ์');const reason=safeCellText_(payload.reason,500);if(!reason)throw createAppError_('VALIDATION_ERROR','กรุณาระบุเหตุผล');const now=new Date().toISOString();updateRecordRow_('ATTACHMENTS',found.rowNumber,{archived_at:now,is_active:false,updated_at:now,updated_by:auth.user.user_id,row_version:Number(found.record.row_version)+1});try{DriveApp.getFileById(String(found.record.drive_file_id)).setTrashed(true);}catch(e){console.error(JSON.stringify({event:'ATTACHMENT_TRASH_FAILED',attachmentId:found.record.attachment_id}));}appendAudit_({requestId:requestId,actorUserId:auth.user.user_id,organizationId:patient.organization_id,actionCode:'ATTACHMENT_ARCHIVE',entityType:'ATTACHMENT',entityId:found.record.attachment_id,reason:reason});return{archived:true};}
function matchesFileSignature_(bytes,mime){const u=bytes.map(function(b){return b<0?b+256:b;});if(mime==='image/jpeg')return u[0]===255&&u[1]===216&&u[2]===255;if(mime==='image/png')return u.slice(0,8).join(',')==='137,80,78,71,13,10,26,10';if(mime==='image/webp')return String.fromCharCode.apply(null,u.slice(0,4))==='RIFF'&&String.fromCharCode.apply(null,u.slice(8,12))==='WEBP';if(mime==='application/pdf')return String.fromCharCode.apply(null,u.slice(0,5))==='%PDF-';return false;}
function publicAttachment_(a){return{attachmentId:String(a.attachment_id),patientId:String(a.patient_id),visitId:String(a.visit_id||''),fileCategory:String(a.file_category),originalName:String(a.original_name),mimeType:String(a.mime_type),sizeBytes:Number(a.size_bytes),caption:String(a.caption||''),capturedAt:String(a.captured_at),consentId:String(a.consent_id||''),uploadedBy:String(a.uploaded_by),accessLevel:String(a.access_level)};}
function canAccessAttachment_(user,a){const level=String(a.access_level||'CARE_TEAM');if(level==='ADMIN_ONLY')return['SUPER_ADMIN','ORG_ADMIN'].indexOf(String(user.role_code))!==-1;if(level==='CLINICIAN_ONLY')return['SUPER_ADMIN','ORG_ADMIN','CLINICIAN'].indexOf(String(user.role_code))!==-1;return true;}
