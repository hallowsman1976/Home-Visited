function listProblems_(auth,payload){requirePermission_(auth.user,'patients.read');const patient=getPatientRecordInScope_(auth.user,payload.patientId);if(!patient)throw createAppError_('NOT_FOUND','ไม่พบผู้ป่วย');return recordsForField_('PROBLEMS','patient_id',patient.patient_id).map(publicProblem_);}
function upsertProblem_(auth,payload,requestId){requirePermission_(auth.user,'patients.write');const patient=getPatientRecordInScope_(auth.user,payload.patientId);if(!patient)throw createAppError_('NOT_FOUND','ไม่พบผู้ป่วย');if(!String(payload.problemText||'').trim())throw createAppError_('VALIDATION_ERROR','กรุณาระบุปัญหา');const now=new Date().toISOString();const changes={visit_id:String(payload.visitId||''),domain_code:safeCellText_(payload.domainCode,10),problem_code:safeCellText_(payload.problemCode,100),problem_text:safeCellText_(payload.problemText,1500),severity:String(payload.severity||'MEDIUM'),priority:Number(payload.priority||1),status:String(payload.status||'OPEN'),resolved_at:String(payload.status)==='RESOLVED'?now:'',updated_at:now,updated_by:auth.user.user_id};let id=String(payload.problemId||'');if(id){const found=findRecordByField_('PROBLEMS','problem_id',id.toLowerCase());if(!found||String(found.record.patient_id)!==String(patient.patient_id))throw createAppError_('NOT_FOUND','ไม่พบปัญหา');changes.row_version=Number(found.record.row_version)+1;updateRecordRow_('PROBLEMS',found.rowNumber,changes);}else{id=Utilities.getUuid();appendRecord_('PROBLEMS',Object.assign({problem_id:id,patient_id:patient.patient_id,identified_at:now,created_at:now,created_by:auth.user.user_id,row_version:1,is_active:true},changes));}appendAudit_({requestId:requestId,actorUserId:auth.user.user_id,organizationId:patient.organization_id,actionCode:'PROBLEM_UPSERT',entityType:'PROBLEM',entityId:id});return{problemId:id,saved:true};}
function listCarePlans_(auth,payload){requirePermission_(auth.user,'patients.read');const patient=getPatientRecordInScope_(auth.user,payload.patientId);if(!patient)throw createAppError_('NOT_FOUND','ไม่พบผู้ป่วย');const problemIds={};recordsForField_('PROBLEMS','patient_id',patient.patient_id).forEach(function(p){problemIds[String(p.problem_id)]=true;});return allActiveRecords_('CARE_PLANS').filter(function(p){return problemIds[String(p.problem_id)];}).map(function(plan){const result=publicCarePlan_(plan);result.interventions=recordsForField_('INTERVENTIONS','care_plan_id',plan.care_plan_id).map(publicIntervention_);return result;});}
function upsertCarePlan_(auth,payload,requestId){requirePermission_(auth.user,'patients.write');const problem=findRecordByField_('PROBLEMS','problem_id',String(payload.problemId||'').toLowerCase());if(!problem)throw createAppError_('NOT_FOUND','ไม่พบปัญหา');const patient=getPatientRecordInScope_(auth.user,problem.record.patient_id);if(!patient)throw createAppError_('FORBIDDEN','ไม่มีสิทธิ์');if(!String(payload.goalText||'').trim())throw createAppError_('VALIDATION_ERROR','กรุณาระบุเป้าหมาย');const now=new Date().toISOString();const changes={goal_text:safeCellText_(payload.goalText,1500),target_date:String(payload.targetDate||''),owner_user_id:String(payload.ownerUserId||auth.user.user_id),owner_team_id:String(payload.ownerTeamId||''),status:String(payload.status||'ACTIVE'),evaluation_text:safeCellText_(payload.evaluationText,1500),updated_at:now,updated_by:auth.user.user_id};let id=String(payload.carePlanId||'');if(id){const found=findRecordByField_('CARE_PLANS','care_plan_id',id.toLowerCase());if(!found||String(found.record.problem_id)!==String(problem.record.problem_id))throw createAppError_('NOT_FOUND','ไม่พบแผน');changes.row_version=Number(found.record.row_version)+1;updateRecordRow_('CARE_PLANS',found.rowNumber,changes);}else{id=Utilities.getUuid();appendRecord_('CARE_PLANS',Object.assign({care_plan_id:id,problem_id:problem.record.problem_id,created_at:now,created_by:auth.user.user_id,row_version:1,is_active:true},changes));}appendAudit_({requestId:requestId,actorUserId:auth.user.user_id,organizationId:patient.organization_id,actionCode:'CARE_PLAN_UPSERT',entityType:'CARE_PLAN',entityId:id});return{carePlanId:id,saved:true};}
function addIntervention_(auth,payload,requestId){requirePermission_(auth.user,'patients.write');const plan=findRecordByField_('CARE_PLANS','care_plan_id',String(payload.carePlanId||'').toLowerCase());if(!plan)throw createAppError_('NOT_FOUND','ไม่พบแผน');const problem=findRecordByField_('PROBLEMS','problem_id',String(plan.record.problem_id).toLowerCase());const patient=problem?getPatientRecordInScope_(auth.user,problem.record.patient_id):null;if(!patient)throw createAppError_('FORBIDDEN','ไม่มีสิทธิ์');if(!String(payload.activityText||'').trim())throw createAppError_('VALIDATION_ERROR','กรุณาระบุกิจกรรม');const now=new Date().toISOString();const id=Utilities.getUuid();appendRecord_('INTERVENTIONS',{intervention_id:id,care_plan_id:plan.record.care_plan_id,visit_id:String(payload.visitId||''),intervention_type:safeCellText_(payload.interventionType,100),activity_text:safeCellText_(payload.activityText,2000),performed_at:String(payload.performedAt||now),performed_by:auth.user.user_id,outcome_text:safeCellText_(payload.outcomeText,1500),created_at:now,created_by:auth.user.user_id,updated_at:now,updated_by:auth.user.user_id,row_version:1,is_active:true});appendAudit_({requestId:requestId,actorUserId:auth.user.user_id,organizationId:patient.organization_id,actionCode:'INTERVENTION_ADD',entityType:'INTERVENTION',entityId:id});return{interventionId:id,created:true};}
function listReferrals_(auth,payload){requirePermission_(auth.user,'patients.read');const patient=getPatientRecordInScope_(auth.user,payload.patientId);if(!patient)throw createAppError_('NOT_FOUND','ไม่พบผู้ป่วย');return recordsForField_('REFERRALS','patient_id',patient.patient_id).map(publicReferral_);}
function upsertReferral_(auth,payload,requestId){requirePermission_(auth.user,'patients.write');const patient=getPatientRecordInScope_(auth.user,payload.patientId);if(!patient)throw createAppError_('NOT_FOUND','ไม่พบผู้ป่วย');if(!String(payload.referredToUnit||'').trim()||!String(payload.reason||'').trim())throw createAppError_('VALIDATION_ERROR','กรุณาระบุหน่วยรับส่งต่อและเหตุผล');const now=new Date().toISOString();const changes={visit_id:String(payload.visitId||''),referred_to_unit:safeCellText_(payload.referredToUnit,300),reason:safeCellText_(payload.reason,1500),urgency:String(payload.urgency||'ROUTINE'),referred_at:String(payload.referredAt||now),status:String(payload.status||'PENDING'),appointment_at:String(payload.appointmentAt||''),result_text:safeCellText_(payload.resultText,1500),updated_at:now,updated_by:auth.user.user_id};let id=String(payload.referralId||'');if(id){const found=findRecordByField_('REFERRALS','referral_id',id.toLowerCase());if(!found||String(found.record.patient_id)!==String(patient.patient_id))throw createAppError_('NOT_FOUND','ไม่พบรายการส่งต่อ');changes.row_version=Number(found.record.row_version)+1;updateRecordRow_('REFERRALS',found.rowNumber,changes);}else{id=Utilities.getUuid();appendRecord_('REFERRALS',Object.assign({referral_id:id,patient_id:patient.patient_id,created_at:now,created_by:auth.user.user_id,row_version:1,is_active:true},changes));}appendAudit_({requestId:requestId,actorUserId:auth.user.user_id,organizationId:patient.organization_id,actionCode:'REFERRAL_UPSERT',entityType:'REFERRAL',entityId:id});return{referralId:id,saved:true};}
function recordsForField_(sheetName,field,value){return allActiveRecords_(sheetName).filter(function(r){return String(r[field])===String(value);});}
function allActiveRecords_(sheetName){const sheet=getDataSheet_(sheetName);if(sheet.getLastRow()<2)return[];const rows=sheet.getDataRange().getValues();const h=rows[0];return rows.slice(1).map(function(r){return rowToObject_(h,r);}).filter(function(r){return String(r.is_active).toLowerCase()!=='false';});}
function publicProblem_(p){return{problemId:String(p.problem_id),patientId:String(p.patient_id),visitId:String(p.visit_id||''),domainCode:String(p.domain_code||''),problemCode:String(p.problem_code||''),problemText:String(p.problem_text),severity:String(p.severity),priority:Number(p.priority),status:String(p.status),identifiedAt:String(p.identified_at||''),resolvedAt:String(p.resolved_at||'')};}
function publicCarePlan_(p){return{carePlanId:String(p.care_plan_id),problemId:String(p.problem_id),goalText:String(p.goal_text),targetDate:String(p.target_date||''),ownerUserId:String(p.owner_user_id||''),ownerTeamId:String(p.owner_team_id||''),status:String(p.status),evaluationText:String(p.evaluation_text||''),interventions:[]};}
function publicIntervention_(i){return{interventionId:String(i.intervention_id),carePlanId:String(i.care_plan_id),visitId:String(i.visit_id||''),interventionType:String(i.intervention_type||''),activityText:String(i.activity_text),performedAt:String(i.performed_at),performedBy:String(i.performed_by),outcomeText:String(i.outcome_text||'')};}
function publicReferral_(r){return{referralId:String(r.referral_id),patientId:String(r.patient_id),visitId:String(r.visit_id||''),referredToUnit:String(r.referred_to_unit),reason:String(r.reason),urgency:String(r.urgency),referredAt:String(r.referred_at),status:String(r.status),appointmentAt:String(r.appointment_at||''),resultText:String(r.result_text||'')};}

