function listConsents_(auth,payload){requirePermission_(auth.user,'patients.read');const patient=getPatientRecordInScope_(auth.user,payload.patientId);if(!patient)throw createAppError_('NOT_FOUND','ไม่พบผู้ป่วย');return recordsForField_('CONSENTS','patient_id',patient.patient_id).map(publicConsent_);}
function upsertConsent_(auth,payload,requestId){requirePermission_(auth.user,'patients.write');const patient=getPatientRecordInScope_(auth.user,payload.patientId);if(!patient)throw createAppError_('NOT_FOUND','ไม่พบผู้ป่วย');if(!String(payload.consentType||'').trim()||!String(payload.purpose||'').trim())throw createAppError_('VALIDATION_ERROR','กรุณาระบุประเภทและวัตถุประสงค์');const allowed=['GRANTED','REFUSED','WITHDRAWN','NOT_REQUIRED'];if(allowed.indexOf(String(payload.status))===-1)throw createAppError_('VALIDATION_ERROR','สถานะ consent ไม่ถูกต้อง');const now=new Date().toISOString();const changes={consent_type:safeCellText_(payload.consentType,100),purpose:safeCellText_(payload.purpose,1000),legal_basis:safeCellText_(payload.legalBasis,300),version:safeCellText_(payload.version||'1.0',50),status:String(payload.status),granted_by:safeCellText_(payload.grantedBy,300),relationship:safeCellText_(payload.relationship,100),recorded_at:String(payload.recordedAt||now),expires_at:String(payload.expiresAt||''),withdrawn_at:String(payload.status)==='WITHDRAWN'?now:'',updated_at:now,updated_by:auth.user.user_id};let id=String(payload.consentId||'');if(id){const found=findRecordByField_('CONSENTS','consent_id',id.toLowerCase());if(!found||String(found.record.patient_id)!==String(patient.patient_id))throw createAppError_('NOT_FOUND','ไม่พบ consent');changes.row_version=Number(found.record.row_version)+1;updateRecordRow_('CONSENTS',found.rowNumber,changes);}else{id=Utilities.getUuid();appendRecord_('CONSENTS',Object.assign({consent_id:id,patient_id:patient.patient_id,created_at:now,created_by:auth.user.user_id,row_version:1,is_active:true},changes));}appendAudit_({requestId:requestId,actorUserId:auth.user.user_id,organizationId:patient.organization_id,actionCode:'CONSENT_UPSERT',entityType:'CONSENT',entityId:id,reason:String(payload.status)});return{consentId:id,saved:true};}
function publicConsent_(c){return{consentId:String(c.consent_id),patientId:String(c.patient_id),consentType:String(c.consent_type),purpose:String(c.purpose),legalBasis:String(c.legal_basis||''),version:String(c.version),status:String(c.status),grantedBy:String(c.granted_by||''),relationship:String(c.relationship||''),recordedAt:String(c.recorded_at),expiresAt:String(c.expires_at||''),withdrawnAt:String(c.withdrawn_at||'')};}
function validConsentForAttachment_(patientId,consentId){if(!consentId)return null;const found=findRecordByField_('CONSENTS','consent_id',String(consentId).toLowerCase());if(!found||String(found.record.patient_id)!==String(patientId)||String(found.record.status)!=='GRANTED')return null;if(found.record.expires_at&&new Date(found.record.expires_at).getTime()<Date.now())return null;return found.record;}

