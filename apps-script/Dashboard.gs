function dashboardSummary_(auth){requirePermission_(auth.user,'dashboard.read');const patients=buildPatientMapForScope_(auth.user);const patientIds=Object.keys(patients);const visits=allActiveRecords_('VISITS').filter(function(v){return patients[String(v.patient_id)];});const followups=listFollowUps_(auth,{});const today=formatIsoDate_(new Date());return{patientsTotal:patientIds.length,patientsHighRisk:patientIds.filter(function(id){return['HIGH','CRITICAL'].indexOf(String(patients[id].risk_level))!==-1;}).length,visitsTotal:visits.length,visitsToday:visits.filter(function(v){return String(v.visit_date)===today;}).length,drafts:visits.filter(function(v){return String(v.status)==='DRAFT'||String(v.status)==='REOPENED';}).length,followUpsPending:followups.filter(function(f){return f.status==='PENDING';}).length,followUpsOverdue:followups.filter(function(f){return f.status==='OVERDUE';}).length,recentVisits:visits.sort(function(a,b){return String(b.visit_date).localeCompare(String(a.visit_date));}).slice(0,5).map(function(v){return publicVisit_(v,patients[String(v.patient_id)]);})};}

