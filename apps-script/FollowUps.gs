function listFollowUps_(auth,payload){requirePermission_(auth.user,'visits.read');const patients=buildPatientMapForScope_(auth.user);const today=formatIsoDate_(new Date());const statusFilter=String(payload.status||'');const patientFilter=String(payload.patientId||'');return allActiveRecords_('FOLLOW_UPS').filter(function(f){if(!patients[String(f.patient_id)]||(patientFilter&&String(f.patient_id)!==patientFilter))return false;const effectiveStatus=String(f.status)==='PENDING'&&String(f.due_at).slice(0,10)<today?'OVERDUE':String(f.status);f._effective_status=effectiveStatus;return !statusFilter||effectiveStatus===statusFilter;}).sort(function(a,b){return String(a.due_at).localeCompare(String(b.due_at));}).slice(0,100).map(function(f){const p=patients[String(f.patient_id)];return publicFollowUp_(f,p);});}
function upsertFollowUp_(auth,payload,requestId){if(!hasPermission_(auth.user,'followups.write')&&!hasPermission_(auth.user,'visits.write'))throw createAppError_('FORBIDDEN','ไม่มีสิทธิ์จัดการติดตาม');const patient=getPatientRecordInScope_(auth.user,payload.patientId);if(!patient)throw createAppError_('NOT_FOUND','ไม่พบผู้ป่วย');if(!payload.dueAt)throw createAppError_('VALIDATION_ERROR','กรุณาระบุวันติดตาม');const now=new Date().toISOString();const changes={visit_id:String(payload.visitId||''),follow_up_type:String(payload.followUpType||'HOME_VISIT'),due_at:String(payload.dueAt),assigned_to_user_id:String(payload.assignedToUserId||auth.user.user_id),assigned_team_id:String(payload.assignedTeamId||''),priority:String(payload.priority||'MEDIUM'),status:String(payload.status||'PENDING'),completed_at:String(payload.status)==='DONE'?String(payload.completedAt||now):'',result_text:safeCellText_(payload.resultText,1500),updated_at:now,updated_by:auth.user.user_id};let id=String(payload.followUpId||'');if(id){const found=findRecordByField_('FOLLOW_UPS','follow_up_id',id.toLowerCase());if(!found||String(found.record.patient_id)!==String(patient.patient_id))throw createAppError_('NOT_FOUND','ไม่พบงานติดตาม');changes.row_version=Number(found.record.row_version)+1;updateRecordRow_('FOLLOW_UPS',found.rowNumber,changes);}else{id=Utilities.getUuid();appendRecord_('FOLLOW_UPS',Object.assign({follow_up_id:id,patient_id:patient.patient_id,created_at:now,created_by:auth.user.user_id,row_version:1,is_active:true},changes));}appendAudit_({requestId:requestId,actorUserId:auth.user.user_id,organizationId:patient.organization_id,actionCode:'FOLLOW_UP_UPSERT',entityType:'FOLLOW_UP',entityId:id});return{followUpId:id,saved:true};}
function publicFollowUp_(f,p){return{followUpId:String(f.follow_up_id),patientId:String(f.patient_id),patientName:p?[p.title,p.first_name,p.last_name].filter(String).join(' '):'',hn:p?String(p.hn):'',visitId:String(f.visit_id||''),followUpType:String(f.follow_up_type),dueAt:String(f.due_at),assignedToUserId:String(f.assigned_to_user_id||''),priority:String(f.priority),status:String(f._effective_status||f.status),completedAt:String(f.completed_at||''),resultText:String(f.result_text||'')};}
