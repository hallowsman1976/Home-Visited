function listMedications_(auth,payload){requirePermission_(auth.user,'patients.read');const sheet=getDataSheet_('MEDICATIONS');if(sheet.getLastRow()<2)return[];const q=String(payload.query||'').toLowerCase();const rows=sheet.getDataRange().getValues();const h=rows[0];return rows.slice(1).map(function(r){return rowToObject_(h,r);}).filter(function(m){if(String(m.is_active).toLowerCase()==='false')return false;if(m.organization_id&&auth.user.role_code!=='SUPER_ADMIN'&&String(m.organization_id)!==String(auth.user.organization_id))return false;return !q||[m.drug_code,m.generic_name,m.trade_name].join(' ').toLowerCase().indexOf(q)!==-1;}).slice(0,100).map(publicMedication_);}
function upsertMedication_(auth,payload,requestId){if(['SUPER_ADMIN','ORG_ADMIN'].indexOf(String(auth.user.role_code))===-1)throw createAppError_('FORBIDDEN','เฉพาะผู้ดูแลระบบที่จัดการบัญชียาได้');if(!String(payload.genericName||'').trim())throw createAppError_('VALIDATION_ERROR','กรุณาระบุชื่อสามัญยา');const now=new Date().toISOString();if(payload.medicationId){const found=findRecordByField_('MEDICATIONS','medication_id',String(payload.medicationId).toLowerCase());if(!found)throw createAppError_('NOT_FOUND','ไม่พบยา');updateRecordRow_('MEDICATIONS',found.rowNumber,{drug_code:safeCellText_(payload.drugCode,100),generic_name:safeCellText_(payload.genericName,300),trade_name:safeCellText_(payload.tradeName,300),strength:safeCellText_(payload.strength,100),dosage_form:safeCellText_(payload.dosageForm,100),updated_at:now,updated_by:auth.user.user_id,row_version:Number(found.record.row_version)+1});return publicMedication_(Object.assign({},found.record,payload));}const record={medication_id:Utilities.getUuid(),organization_id:auth.user.organization_id,drug_code:safeCellText_(payload.drugCode,100),generic_name:safeCellText_(payload.genericName,300),trade_name:safeCellText_(payload.tradeName,300),strength:safeCellText_(payload.strength,100),dosage_form:safeCellText_(payload.dosageForm,100),created_at:now,created_by:auth.user.user_id,updated_at:now,updated_by:auth.user.user_id,row_version:1,is_active:true};appendRecord_('MEDICATIONS',record);appendAudit_({requestId:requestId,actorUserId:auth.user.user_id,organizationId:auth.user.organization_id,actionCode:'MEDICATION_MASTER_CREATE',entityType:'MEDICATION',entityId:record.medication_id});return publicMedication_(record);}
function listVisitMedications_(auth,payload){requirePermission_(auth.user,'visits.read');const visit=getVisitRecordInScope_(auth.user,payload.visitId);if(!visit)throw createAppError_('NOT_FOUND','ไม่พบรายการเยี่ยม');const sheet=getDataSheet_('VISIT_MEDICATIONS');if(sheet.getLastRow()<2)return[];const rows=sheet.getDataRange().getValues();const h=rows[0];return rows.slice(1).map(function(r){return rowToObject_(h,r);}).filter(function(m){return String(m.visit_id)===String(visit.visit_id)&&String(m.is_active).toLowerCase()!=='false';}).map(publicVisitMedication_);}
function upsertVisitMedication_(auth,payload,requestId){requirePermission_(auth.user,'visits.write');const visit=getVisitRecordInScope_(auth.user,payload.visitId);if(!visit)throw createAppError_('NOT_FOUND','ไม่พบรายการเยี่ยม');if(!String(payload.drugNameSnapshot||'').trim())throw createAppError_('VALIDATION_ERROR','กรุณาระบุชื่อยา');const now=new Date().toISOString();const changes={medication_id:String(payload.medicationId||''),drug_name_snapshot:safeCellText_(payload.drugNameSnapshot,300),dose:safeCellText_(payload.dose,100),route:safeCellText_(payload.route,100),frequency:safeCellText_(payload.frequency,100),indication:safeCellText_(payload.indication,300),actual_use:safeCellText_(payload.actualUse,300),adherence_level:safeCellText_(payload.adherenceLevel,50),drug_related_problem:safeCellText_(payload.drugRelatedProblem,1000),action_taken:safeCellText_(payload.actionTaken,1000),updated_at:now,updated_by:auth.user.user_id};let id=String(payload.visitMedicationId||'');if(id){const found=findRecordByField_('VISIT_MEDICATIONS','visit_medication_id',id.toLowerCase());if(!found||String(found.record.visit_id)!==String(visit.visit_id))throw createAppError_('NOT_FOUND','ไม่พบรายการยา');changes.row_version=Number(found.record.row_version)+1;updateRecordRow_('VISIT_MEDICATIONS',found.rowNumber,changes);}else{id=Utilities.getUuid();appendRecord_('VISIT_MEDICATIONS',Object.assign({visit_medication_id:id,visit_id:visit.visit_id,created_at:now,created_by:auth.user.user_id,row_version:1,is_active:true},changes));}appendAudit_({requestId:requestId,actorUserId:auth.user.user_id,organizationId:auth.user.organization_id,actionCode:'VISIT_MEDICATION_UPSERT',entityType:'VISIT',entityId:visit.visit_id,changedFields:['medication']});return{visitMedicationId:id,saved:true};}
function publicMedication_(m){return{medicationId:String(m.medication_id),drugCode:String(m.drug_code||''),genericName:String(m.generic_name||m.genericName||''),tradeName:String(m.trade_name||m.tradeName||''),strength:String(m.strength||''),dosageForm:String(m.dosage_form||m.dosageForm||'')};}
function publicVisitMedication_(m){return{visitMedicationId:String(m.visit_medication_id),visitId:String(m.visit_id),medicationId:String(m.medication_id||''),drugNameSnapshot:String(m.drug_name_snapshot),dose:String(m.dose||''),route:String(m.route||''),frequency:String(m.frequency||''),indication:String(m.indication||''),actualUse:String(m.actual_use||''),adherenceLevel:String(m.adherence_level||''),drugRelatedProblem:String(m.drug_related_problem||''),actionTaken:String(m.action_taken||'')};}
function getVisitRecordInScope_(user,visitId){const found=findRecordByField_('VISITS','visit_id',String(visitId||'').toLowerCase());if(!found)return null;return getPatientRecordInScope_(user,found.record.patient_id)?found.record:null;}

