function reportVisits_(auth,payload){requirePermission_(auth.user,'reports.read');const patients=buildPatientMapForScope_(auth.user);const from=String(payload.dateFrom||'');const to=String(payload.dateTo||'');const rows=allActiveRecords_('VISITS').filter(function(v){if(!patients[String(v.patient_id)])return false;const date=String(v.visit_date);return(!from||date>=from)&&(!to||date<=to);}).sort(function(a,b){return String(b.visit_date).localeCompare(String(a.visit_date));}).slice(0,500).map(function(v){return publicVisit_(v,patients[String(v.patient_id)]);});return{items:rows,total:rows.length,dateFrom:from,dateTo:to,limit:500};}
function exportVisits_(auth,payload,requestId){requirePermission_(auth.user,'reports.export');const report=reportVisits_(auth,payload);const headers=['visit_date','hn','patient_name','visit_no','visit_type','location_type','overall_risk','status','next_visit_date'];const lines=[headers.join(',')].concat(report.items.map(function(v){return[v.visitDate,v.hn,v.patientName,v.visitNo,v.visitType,v.locationType,v.overallRisk,v.status,v.nextVisitDate].map(csvEscape_).join(',');}));const csv='\uFEFF'+lines.join('\r\n');const filename='visit-report-'+(report.dateFrom||'all')+'-'+(report.dateTo||'all')+'.csv';appendAudit_({requestId:requestId,actorUserId:auth.user.user_id,organizationId:auth.user.organization_id,actionCode:'REPORT_EXPORT',entityType:'VISIT_REPORT',reason:'CSV '+report.total+' rows'});return{fileName:filename,mimeType:'text/csv;charset=utf-8',contentBase64:Utilities.base64Encode(csv,Utilities.Charset.UTF_8),rows:report.total};}
function csvEscape_(value){const text=String(value===undefined?'':value);return'"'+text.replace(/"/g,'""')+'"';}

